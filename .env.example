# TrialIntel Environment Configuration
# Copy this file to .env and customize for your environment

# =============================================================================
# ENVIRONMENT
# =============================================================================
ENVIRONMENT=development  # development, testing, production

# =============================================================================
# DATABASE
# =============================================================================
# SQLite (default for development)
DATABASE_URL=sqlite:///./data/trials.db

# PostgreSQL (recommended for production)
# DATABASE_URL=postgresql://user:password@localhost:5432/trialintel

DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_ECHO=false

# =============================================================================
# API SERVER
# =============================================================================
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false
API_RELOAD=false

# CORS - Comma-separated list of allowed origins
# For production, specify exact domains
CORS_ORIGINS=http://localhost:3000,http://localhost:8501
CORS_ALLOW_CREDENTIALS=true

# =============================================================================
# API AUTHENTICATION
# =============================================================================
# Set to true to require API key for all endpoints
REQUIRE_API_KEY=false

# Comma-separated list of valid API keys
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEYS=

# =============================================================================
# RATE LIMITING
# =============================================================================
RATE_LIMIT_REQUESTS=100  # Max requests per window
RATE_LIMIT_WINDOW=60     # Window in seconds

# =============================================================================
# AI / ANTHROPIC
# =============================================================================
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-20250514
CLAUDE_MAX_TOKENS=1024

# =============================================================================
# CACHING
# =============================================================================
CACHE_ENABLED=true
CACHE_TTL=300  # seconds

# Redis URL (optional - for distributed caching)
# REDIS_URL=redis://localhost:6379/0

# =============================================================================
# LOGGING
# =============================================================================
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s
LOG_JSON=false  # Set to true for JSON logging (recommended for production)
LOG_FILE=       # Optional: path to log file

# =============================================================================
# DATA INGESTION
# =============================================================================
TRIALINTEL_DATA_DIR=./data
CTGOV_RATE_LIMIT=0.1  # Delay between API calls (seconds)
INGESTION_BATCH_SIZE=100

# =============================================================================
# JEEVA INTEGRATION (Webhooks)
# =============================================================================
JEEVA_API_URL=
JEEVA_API_KEY=
JEEVA_WEBHOOK_SECRET=
